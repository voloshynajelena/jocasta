# Database
DATABASE_URL="postgresql://jocasta:jocasta_dev_password@localhost:5432/jocasta?schema=public"

# Server
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here-replace-in-production
JWT_REFRESH_SECRET=your-refresh-secret-here-replace-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/auth/google/callback

# Google APIs
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# AI (OpenAI)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Expo Push Notifications (optional)
EXPO_ACCESS_TOKEN=your-expo-access-token

# Default Location (Calgary)
DEFAULT_TIMEZONE=America/Edmonton
DEFAULT_LATITUDE=51.0447
DEFAULT_LONGITUDE=-114.0719

# CORS
CORS_ORIGIN=http://localhost:8081,http://localhost:19006,http://localhost:3000

# Logging
LOG_LEVEL=info
